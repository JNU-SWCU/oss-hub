{
  "name": "oss-hub",
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.0.0",
  "scripts": {
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "team-state:check": "node scripts/team-state-check.mjs",
    "team-state:check:test": "node --test scripts/team-state-check.test.mjs",
    "db:up": "docker compose -f compose.dev.yml up -d --wait",
    "db:migrate:dev": "pnpm --filter backend db:migrate:dev",
    "db:reset": "pnpm --filter backend db:reset",
    "postinstall": "pnpm --filter backend exec prisma generate"
  }
}
