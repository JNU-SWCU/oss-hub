#!/usr/bin/env bash
set -uo pipefail

failed=0
while IFS= read -r -d '' path; do
  if ! git show ":$path" | corepack pnpm --filter backend exec eslint \
    --stdin --stdin-filename "${path#apps/backend/}"; then
    failed=1
  fi
done < <(git diff --cached --name-only --diff-filter=ACMR -z -- \
  ':(glob)apps/backend/src/**/dto/*.ts')

exit "$failed"
