generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// 사용자 역할. 신규 사용자는 역할 선택 전 null이다(#109 계약 잠금) — @default를 두지 않는다.
enum Role {
  STUDENT
  STAFF
  ADMIN
}

/// 계정 생명주기. 역할과 독립적으로 권한 접근 가능 여부를 결정한다(#187, #188).
enum AccountStatus {
  ACTIVE
  DEACTIVATED
}

model User {
  id            String        @id @default(cuid())
  githubId      BigInt        @unique
  login         String
  name          String?
  studentId     String?
  department    String?
  avatarUrl     String?
  accountStatus AccountStatus @default(ACTIVE)
  /// 역할 선택 전 null, 학생 선택 시 STUDENT, 교직원 요청 승인 시에만 STAFF가 된다(#109).
  role          Role?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  roleRequests          RoleRequest[]        @relation("RoleRequestUser")
  decidedRoleRequests   RoleRequest[]        @relation("RoleRequestDecidedBy")
  consents              Consent[]
  applications          Application[]        @relation("ApplicationApplicant")
  processedApplications Application[]        @relation("ApplicationProcessedBy")
  ledTeams              Team[]               @relation("TeamLeader")
  teamMemberships       TeamMember[]
  submissionRevisions   SubmissionRevision[]
  uploadedFiles         SubmissionFile[]
  reviews               Review[]
  notifications         Notification[]
  auditLogs             AuditLog[]
  loginHistories        LoginHistory[]
}

enum LoginHistoryEvent {
  LOGIN
  LOGOUT
}

/// 로그인 활동 기록. IP·User-Agent는 수집하지 않는다(#157).
model LoginHistory {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  event    LoginHistoryEvent
  provider String            @default("github")
  success  Boolean
  loginAt  DateTime          @default(now())

  @@index([userId, loginAt])
}

/// PENDING → APPROVED/REJECTED. REVOKED는 회수(REVOKE) 이력을 표현한다(#109 계약 잠금 이행 — #113에서 additive로 추가).
enum RoleRequestStatus {
  PENDING
  APPROVED
  REJECTED
  REVOKED
}

/// 교직원 권한 요청 이력. 회수(REVOKE)도 상태를 지우지 않고 이력으로 남긴다(#108이 소비).
/// 사용자당 PENDING 1건 제한 partial unique는 Prisma로 표현할 수 없어 마이그레이션 SQL에 둔다(#164).
model RoleRequest {
  id     String @id @default(cuid())
  userId String
  user   User   @relation("RoleRequestUser", fields: [userId], references: [id])

  status          RoleRequestStatus @default(PENDING)
  rejectionReason String?

  decidedById String?
  decidedBy   User?     @relation("RoleRequestDecidedBy", fields: [decidedById], references: [id])
  decidedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

/// 전역 개인정보·활동 동의. MVP는 정책 버전별 1회 동의만 저장한다(#109 계약 잠금) — programId를 두지 않는다.
model Consent {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  policyVersion String
  consentedAt   DateTime @default(now())

  @@unique([userId, policyVersion])
}

/// 프로그램 유형 7종 고정(#109 계약 잠금) — 임의 필드 빌더는 post-pilot.
enum ProgramCategory {
  BASIC
  SW_VALUE_SPREAD
  OSS_CONTEST
  CAPSTONE
  SW_CONVERGENCE
  GLOBAL_MAKERTHON
  CORPORATE_INTERNSHIP
}

/// 기간·팀 인원 CHECK 3건은 Prisma로 표현할 수 없어 마이그레이션 SQL에 둔다(#164).
/// NULL 피연산자는 CHECK를 통과하므로 개인형 프로그램의 nullable 인원 필드는 유지된다.
model Program {
  id        String          @id @default(cuid())
  name      String
  organizer String
  category  ProgramCategory

  /// 서버 고정 registry가 결정한다(#100) — 클라이언트가 임의 값을 보낼 수 없다.
  applicationTemplateKey     String
  applicationTemplateVersion Int

  applicationStartAt DateTime
  applicationEndAt   DateTime

  /// 개인형 프로그램은 둘 다 null이다(#109 계약 잠금).
  teamMinSize Int?
  teamMaxSize Int?

  description String

  /// Intake 프로그램은 false, Full-loop 프로그램만 true로 켤 수 있다(#113).
  repositoryProvisioningEnabled Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  milestones   Milestone[]
  applications Application[]
  teams        Team[]
  repositories Repository[]
}

/// 제출물 유형 — #113 Submission·#115 제출 API가 정확히 이 값 이름을 사용한다.
enum MilestoneSubmissionType {
  FILE
  TEXT
  REPOSITORY_RELEASE
}

model Milestone {
  id        String  @id @default(cuid())
  programId String
  program   Program @relation(fields: [programId], references: [id])

  name           String
  dueAt          DateTime
  submissionType MilestoneSubmissionType
  instructions   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  submissions Submission[]

  @@index([programId])
}

enum ApplicationStatus {
  SUBMITTED
  APPROVED
  REJECTED
}

/// teamId는 nullable이다 — 개인형은 null, 팀형만 API 검증으로 필수(#109 계약 잠금).
/// 개인·팀 중복 신청 방지 partial unique는 Prisma로 표현할 수 없어 마이그레이션 SQL에 둔다(#164).
model Application {
  id        String  @id @default(cuid())
  programId String
  program   Program @relation(fields: [programId], references: [id])

  applicantId String
  applicant   User   @relation("ApplicationApplicant", fields: [applicantId], references: [id])

  teamId String?
  team   Team?   @relation(fields: [teamId], references: [id])

  /// 7종 고정 템플릿 field별 응답(#118 계약을 따른다).
  answers                    Json
  applicationTemplateVersion Int

  status          ApplicationStatus @default(SUBMITTED)
  rejectionReason String?

  submittedAt DateTime @default(now())

  processedById String?
  processedBy   User?     @relation("ApplicationProcessedBy", fields: [processedById], references: [id])
  processedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  submissions  Submission[]
  repository   Repository?
  provisionJob RepositoryProvisionJob?

  @@index([programId])
  @@index([applicantId])
  @@index([teamId])
}

model Team {
  id        String  @id @default(cuid())
  programId String
  program   Program @relation(fields: [programId], references: [id])

  name           String
  /// 참여코드는 평문을 저장하지 않고 HMAC-SHA-256 digest만 저장한다(#164).
  /// 전역 고유다(프로그램 범위 고유보다 강한 조건이라 #105 요구를 포함한다). 로그에 남기지 않는다(#105).
  joinCodeDigest String @unique

  leaderId String
  leader   User   @relation("TeamLeader", fields: [leaderId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members      TeamMember[]
  applications Application[]
  repositories Repository[]

  /// TeamMember의 비정규화 programId를 composite FK로 검증하기 위한 참조 대상(#164).
  @@unique([id, programId])
  @@index([programId])
}

/// 학과·이름·연락처·이메일은 합류 시 본인 입력(#109) — 팀장 생성 시점엔 비어 있을 수 있어 nullable로 둔다.
model TeamMember {
  id        String @id @default(cuid())
  teamId    String
  /// Team.programId의 비정규화 사본. composite FK가 팀과 프로그램의 정합을 강제한다(#164).
  programId String
  team      Team   @relation(fields: [teamId, programId], references: [id, programId])
  userId    String
  user      User   @relation(fields: [userId], references: [id])

  department String?
  name       String?
  phone      String?
  email      String?

  createdAt DateTime @default(now())

  @@unique([teamId, userId])
  @@unique([programId, userId])
  @@index([userId])
}

/// 제출 현재 상태. REJECTED는 최종 반려, CHANGES_REQUESTED만 재제출 가능하다(#113 상태 enum 계약). D-day/OVERDUE는 Milestone.dueAt 파생 표시값이며 여기 저장하지 않는다.
enum SubmissionStatus {
  SUBMITTED
  APPROVED
  CHANGES_REQUESTED
  REJECTED
}

/// application×milestone당 제출 헤더. 재제출은 SubmissionRevision을 새로 추가하고 currentRevision만 갱신한다(#113).
model Submission {
  id String @id @default(cuid())

  milestoneId String
  milestone   Milestone @relation(fields: [milestoneId], references: [id])

  applicationId String
  application   Application @relation(fields: [applicationId], references: [id])

  status          SubmissionStatus @default(SUBMITTED)
  currentRevision Int              @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  revisions SubmissionRevision[]

  @@unique([applicationId, milestoneId])
  @@index([milestoneId])
}

/// 제출 이력. 재제출 시 이전 revision을 갱신·삭제하지 않고 새 행을 추가한다(#113).
model SubmissionRevision {
  id String @id @default(cuid())

  submissionId String
  submission   Submission @relation(fields: [submissionId], references: [id])

  revision Int

  submissionType MilestoneSubmissionType
  content        Json
  comment        String?

  submittedById String
  submittedBy   User     @relation(fields: [submittedById], references: [id])
  submittedAt   DateTime @default(now())

  files  SubmissionFile[]
  review Review?

  @@unique([submissionId, revision])
  @@index([submittedById])
}

/// storage key만 저장한다 — filesystem 절대경로·public URL을 저장/노출하지 않는다(#113). 미사용 임시 업로드 정리 정책은 #115가 적용한다.
model SubmissionFile {
  id String @id @default(cuid())

  uploaderId String
  uploader   User   @relation(fields: [uploaderId], references: [id])

  storageKey       String
  originalFileName String
  mimeType         String
  sizeBytes        Int

  submissionRevisionId String?
  submissionRevision   SubmissionRevision? @relation(fields: [submissionRevisionId], references: [id])

  createdAt DateTime @default(now())

  @@index([uploaderId])
  @@index([submissionRevisionId])
}

/// 판정: APPROVED/REJECTED/CHANGES_REQUESTED. 제출 판정과 저장소 공개 전환 상태를 같은 필드로 합치지 않는다(#113).
enum ReviewDecision {
  APPROVED
  REJECTED
  CHANGES_REQUESTED
}

model Review {
  id String @id @default(cuid())

  submissionRevisionId String             @unique
  submissionRevision   SubmissionRevision @relation(fields: [submissionRevisionId], references: [id])

  reviewerId String
  reviewer   User   @relation(fields: [reviewerId], references: [id])

  decision   ReviewDecision
  comment    String?
  reviewedAt DateTime       @default(now())

  @@index([reviewerId])
}

/// 공개 범위(#113 상태 enum 계약).
enum RepositoryVisibility {
  PRIVATE
  PUBLIC
}

/// application id당 최대 한 건 — 개인형도 지원해야 하므로 programId+teamId unique로 식별하지 않는다(#113 계약 잠금).
model Repository {
  id String @id @default(cuid())

  applicationId String      @unique
  application   Application @relation(fields: [applicationId], references: [id])

  programId String
  program   Program @relation(fields: [programId], references: [id])

  teamId String?
  team   Team?   @relation(fields: [teamId], references: [id])

  githubRepositoryId BigInt @unique
  name               String
  url                String

  visibility  RepositoryVisibility @default(PRIVATE)
  publishedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invitations  RepositoryInvitation[]
  provisionJob RepositoryProvisionJob?
  orgInventory OrgRepositoryInventory?

  @@index([programId])
  @@index([teamId])
}

/// 공개 랭킹이 신청 데이터 join 없이 저장소 수신자를 찾는 최소 projection(#197).
model RepositoryOwnerProjection {
  githubRepositoryId BigInt   @id
  ownerGithubId      BigInt
  ownerGithubLogin   String
  updatedAt          DateTime @updatedAt

  @@index([ownerGithubId])
}

/// Org 전체 저장소의 canonical identity. program/team 매핑이 없는 저장소도 독립적으로 유지한다(#177).
model OrgRepositoryInventory {
  id String @id @default(cuid())

  githubRepositoryId BigInt               @unique
  fullName           String
  visibility         RepositoryVisibility
  archived           Boolean

  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @default(now())

  repositoryId String?     @unique
  repository   Repository? @relation(fields: [repositoryId], references: [id], onDelete: SetNull)

  activityEvents OrgRepositoryActivityEvent[]
}

/// webhook 원문 없이 저장소 단위 파생 metric delta만 보존하는 최소 활동 이력(#177).
model OrgRepositoryActivityEvent {
  id String @id @default(cuid())

  inventoryId String
  inventory   OrgRepositoryInventory @relation(fields: [inventoryId], references: [id], onDelete: Restrict)

  deliveryId String   @unique
  eventType  String
  occurredAt DateTime
  dedupeKey  String   @unique

  commitDelta      Int @default(0)
  pullRequestDelta Int @default(0)
  starDelta        Int @default(0)

  @@index([inventoryId, occurredAt])
}

enum GithubWebhookObservationOutcome {
  ACCEPTED
  DUPLICATE
  IGNORED
  FAILED
}

/// 검증된 webhook delivery의 처리 결과만 보존한다. payload·signature·header는 저장하지 않는다(#215).
model GithubWebhookObservation {
  id String @id @default(cuid())

  deliveryId  String
  eventType   String
  receivedAt  DateTime
  processedAt DateTime @default(now())

  outcome   GithubWebhookObservationOutcome
  errorCode String?

  @@index([deliveryId])
  @@index([receivedAt])
  @@index([outcome, receivedAt])
}

enum RepositoryInvitationStatus {
  PENDING
  SUCCEEDED
  FAILED_RETRYABLE
  FAILED_FINAL
}

model RepositoryInvitation {
  id String @id @default(cuid())

  repositoryId String
  repository   Repository @relation(fields: [repositoryId], references: [id])

  githubLogin String

  status       RepositoryInvitationStatus @default(PENDING)
  attemptCount Int                        @default(0)

  lastErrorCode    String?
  lastErrorMessage String?
  processedAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([repositoryId, githubLogin])
}

enum OutboxEventStatus {
  PENDING
  PROCESSING
  PROCESSED
  FAILED
}

/// idempotencyKey unique로 outbox 중복 처리를 방지한다. worker claim은 (status, availableAt) 인덱스를 사용한다(#113 계약).
model OutboxEvent {
  id String @id @default(cuid())

  type          String
  aggregateType String
  aggregateId   String

  idempotencyKey String @unique
  payload        Json

  status       OutboxEventStatus @default(PENDING)
  attemptCount Int               @default(0)
  availableAt  DateTime          @default(now())

  lockedAt DateTime?
  lockedBy String?

  processedAt DateTime?
  lastError   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, availableAt])
}

enum RepositoryProvisionJobStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED_RETRYABLE
  FAILED_FINAL
}

/// application id당 최대 한 건. worker claim은 (status, nextAttemptAt) 인덱스를 사용한다(#113 계약).
model RepositoryProvisionJob {
  id String @id @default(cuid())

  applicationId String      @unique
  application   Application @relation(fields: [applicationId], references: [id])

  repositoryId String?     @unique
  repository   Repository? @relation(fields: [repositoryId], references: [id])

  status        RepositoryProvisionJobStatus @default(PENDING)
  attemptCount  Int                          @default(0)
  nextAttemptAt DateTime                     @default(now())

  lockedAt DateTime?
  lockedBy String?

  lastErrorCode    String?
  lastErrorMessage String?

  startedAt  DateTime?
  finishedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, nextAttemptAt])
}

/// outbox나 저장소 job을 Notification으로 대신 구현하지 않는다(#113 계약).
model Notification {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  type    String
  payload Json
  channel String
  status  String

  sentAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

/// outbox나 job을 AuditLog로 대신 구현하지 않는다(#113 계약).
model AuditLog {
  id String @id @default(cuid())

  actorId String
  actor   User   @relation(fields: [actorId], references: [id])

  action     String
  targetType String
  targetId   String
  metadata   Json

  occurredAt DateTime @default(now())

  @@index([actorId])
}

enum CollectionTrigger {
  SELF
  BATCH
}

enum CollectionRunStatus {
  RUNNING
  SUCCEEDED
  FAILED
  RATE_LIMITED
}

enum ObservationSourceType {
  PROFILE
  REPO
  EVENT
}

model CollectionRun {
  id               String                 @id @default(cuid())
  targetGithubId   BigInt
  targetLogin      String
  trigger          CollectionTrigger
  status           CollectionRunStatus
  profileCount     Int                    @default(0)
  repoCount        Int                    @default(0)
  eventCount       Int                    @default(0)
  retryNotBeforeAt DateTime?
  startedAt        DateTime               @default(now())
  finishedAt       DateTime?
  observations     GithubRawObservation[]
}

model GithubRawObservation {
  id         String                @id @default(cuid())
  runId      String
  run        CollectionRun         @relation(fields: [runId], references: [id])
  sourceType ObservationSourceType
  sourceId   String
  payload    Json
  fetchedAt  DateTime              @default(now())

  @@unique([runId, sourceType, sourceId])
}
