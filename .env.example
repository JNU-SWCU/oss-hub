# 운영 환경값은 배포 서버의 .env에서만 관리합니다.
# 개발 PostgreSQL 값은 compose.dev.yml에 인라인으로 정의하며, 마이그레이션 연결 문자열은 backend 패키지 스크립트가 주입합니다.
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
DATABASE_URL=
FRONT_PORT=
BACK_PORT=

# GitHub OAuth 로그인 (backend). 운영은 client ID/secret이 필수이며 callback은 FRONTEND_URL에서 파생합니다.
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
# 선택 호환값. 설정하면 FRONTEND_URL과 같은 origin의 /api/v1/auth/github/callback이어야 합니다.
GITHUB_OAUTH_CALLBACK_URL=

# GitHub 활동 수집 batch allowlist. 실값은 배포 config store에만 두고 repo·PR·로그에 남기지 않습니다.
GITHUB_BATCH_LOGINS=

# 세션 서명 키 — base64url 32바이트 이상. 생성: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
SESSION_SECRET=
# 로그인 후 redirect 대상이자 허용 Origin. 개발 기본값 http://localhost:3000
FRONTEND_URL=

# 테스트 전용 역할 매핑 (Issue #65) — 형식 "githubId:STAFF|STUDENT|ADMIN" 쉼표 구분.
# non-production 전용: 운영에서 설정이 존재하면 기동이 실패한다. 실값은 non-prod env에만 둔다.
AUTH_TEST_ROLE_MAP=

# 팀 참여코드 HMAC-SHA-256 digest 키 (#164) — Team에는 평문 대신 digest만 저장한다.
# 생성: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
# 미설정 시 개발·테스트는 합성 기본키로 동작하고, 운영(NODE_ENV=production)은 즉시 실패한다.
TEAM_JOIN_CODE_SECRET=
